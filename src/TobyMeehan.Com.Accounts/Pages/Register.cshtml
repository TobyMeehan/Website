@page
@using Microsoft.AspNetCore.Mvc.ModelBinding
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model TobyMeehan.Com.Accounts.Pages.Register
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<form method="post">
    <div class="mb-3 row">
        <label asp-for="Form.Username">Username</label>
        <div class="col-sm-10">
            <input asp-for="Form.Username" type="text" class="form-control 
                @(ModelState.GetFieldValidationState("Form.Username") == ModelValidationState.Invalid ? "is-invalid" : "")" />
            <span asp-validation-for="Form.Username" class="invalid-feedback"></span>
        </div>
    </div>
    
    <div class="mb-3 row">
        <label asp-for="Form.Password">Password</label>
        <div class="col-sm-10">
            <input asp-for="Form.Password" type="password" class="form-control
                @(ModelState.GetFieldValidationState("Form.Password") == ModelValidationState.Invalid ? "is-invalid" : "")" />
            <span asp-validation-for="Form.Password" class="invalid-feedback"></span>
        </div>
    </div>
    
    <div class="mb-3 row">
        <label asp-for="Form.ConfirmPassword">Confirm Password</label>
        <div class="col-sm-10">
            <input asp-for="Form.ConfirmPassword" type="password" class="form-control 
                @(ModelState.GetFieldValidationState("Form.ConfirmPassword") == ModelValidationState.Invalid ? "is-invalid" : "")" />
            <span asp-validation-for="Form.ConfirmPassword" class="invalid-feedback"></span>
        </div>
    </div>
    
    <button type="submit" class="btn btn-primary">Register</button>
</form>
