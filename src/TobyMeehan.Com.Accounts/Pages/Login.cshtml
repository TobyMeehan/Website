@page
@using Microsoft.AspNetCore.Mvc.ModelBinding
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model TobyMeehan.Com.Accounts.Pages.Login
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h2 class="text-3xl font-extralight mb-7 text-center">Log In</h2>

<form method="post">
    
    <div class="my-3">
        <label class="block text-md mb-1.5"
               asp-for="Form.Handle">
            Username
        </label>
        <input class="form-control"
               type="text" asp-for="Form.Handle"/>
        <span class="text-sm text-negative"
              asp-validation-for="Form.Handle"></span>
    </div>

    <div class="my-3">
        <label class="block text-md mb-1.5"
               asp-for="Form.Password">
            Password
        </label>
        <input class="form-control"
               type="password" asp-for="Form.Password"/>
        <span class="text-sm text-negative" asp-validation-for="Form.Password"></span>
    </div>

    <button type="submit" class="btn btn-primary my-3 w-full">Log In</button>

    <p>Don't have an account? <a class="link" asp-page="./Register">Register</a></p>
</form>

@section Scripts
{
    <partial name="Shared/_ValidationScriptsPartial"/>
}
