@page
@model TobyMeehan.Com.Accounts.Pages.Login
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h2>Login</h2>

<form method="post">
    <div class="mb-3 row">
        <label for="inputUsername">Username</label>
        <div class="col-sm-10">
            <input type="text" readonly class="form-control-plaintext" id="inputUsername" />
        </div>
    </div>
    
    <div class="mb-3 row">
        <label for="inputPassword">Password</label>
        <div class="col-sm-10">
            <input type="password" readonly class="form-control-plaintext" id="inputPassword" />
        </div>
    </div>
</form>