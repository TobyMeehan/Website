@model LoginViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    Layout = "/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Login";
}

<div class="card-header">
    <h1 class="text-center">Login</h1>
</div>

<div class="card-body">
    <form method="post" asp-antiforgery="true">
        <div class="form-group text-center">
            <label asp-for="@Model.Username" hidden></label>
            <input asp-for="@Model.Username" class="form-control" placeholder="Username" />
            <span asp-validation-for="@Model.Username" class="text-danger"></span>
        </div>
        <div class="form-group text-center">
            <label asp-for="@Model.Password" hidden></label>
            <input asp-for="@Model.Password" class="form-control" placeholder="Password" />
            <span asp-validation-for="@Model.Password" class="text-danger"></span>
        </div>
        <div class="form-group d-flex">
            <div class="flex-grow-1">
                <button type="submit" class="btn btn-outline-light">Login</button>
            </div>
            <p class="my-auto">Don't have an account? <a href="/register?ReturnUrl=@Context.Request.Query["ReturnUrl"]" class="text-darklink">Register</a></p>
        </div>
    </form>

    <hr />

    <p class="lead text-center">OR</p>

    <div class="form-group">
        <a href="/login/discord?ReturnUrl=@Context.Request.Query["ReturnUrl"]" class="btn btn-discord btn-block">
            Login with
            <img src="~/img/full_logo_white_RGB.png" alt="Discord" style="height: 1rem;" />
        </a>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
